# Local development env. Copy to .env.local if you need to override anything.
# Production runs on Cloudflare Workers (see README "Deploy"); there is NO
# platform URL auto-detection there.

# Canonical production origin — REQUIRED for production builds, and INLINED AT
# BUILD TIME by `next build` / `opennextjs-cloudflare build`. The committed
# .env.production already sets it to https://rentrights.soursea.io; a Worker
# runtime var alone CANNOT fix prerendered routes (robots/sitemap/OG).
# A production build that resolves to localhost fails fast (lib/seo/site-url.ts).
NEXT_PUBLIC_SITE_URL=https://rentrights.soursea.io

# Upstream fetch timeout in ms (RUNTIME). Bounds slow LA County / Census calls;
# on timeout the lookup degrades to confirming questions. Default 12000.
# Production: set in wrangler.jsonc "vars" (or leave unset for the default).
UPSTREAM_TIMEOUT_MS=12000

# Search-console verification (RUNTIME, optional — pages render dynamically, so
# Worker vars work). The <meta> tags are omitted until these are set.
# Production: add to wrangler.jsonc "vars" (public meta-tag values, not secrets).
# Preferred: verify a GSC *Domain* property for soursea.io via a Cloudflare DNS
# TXT record instead — then these tokens are unnecessary.
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# Cloudflare Web Analytics beacon token (BUILD TIME, optional). Public by
# design — it ships in every page's HTML. When unset (local dev, self-host),
# no beacon script is rendered at all. The committed .env.production sets the
# production value; create your own Web Analytics site (manual JS snippet) in
# the Cloudflare dashboard if you self-host.
NEXT_PUBLIC_CF_BEACON_TOKEN=
