# Local development env. Copy to .env.local if you need to override anything.
# Production runs on Vercel (see README "Deploy").

# Canonical production origin — REQUIRED for production builds, and INLINED AT
# BUILD TIME by `next build`. The committed .env.production already sets it to
# https://rentrights.writingdeveloper.blog. A production build that resolves to
# localhost fails fast (lib/seo/site-url.ts).
NEXT_PUBLIC_SITE_URL=https://rentrights.writingdeveloper.blog

# Upstream fetch timeout in ms (RUNTIME). Bounds slow LA County / Census calls;
# on timeout the lookup degrades to confirming questions. Default 12000.
# Production: set in the Vercel project env (or leave unset for the default).
UPSTREAM_TIMEOUT_MS=12000

# Search-console verification (RUNTIME, optional — pages render dynamically).
# The <meta> tags are omitted until these are set. Preferred: verify a GSC
# *Domain* property for writingdeveloper.blog via DNS instead — then these
# tokens are unnecessary.
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# Analytics: cookieless Vercel Web Analytics (no token, no consent banner).
# Enable it in the Vercel project's Analytics tab; the <Analytics/> component in
# app/layout.tsx does the rest. Nothing to configure here.
