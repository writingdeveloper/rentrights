# Copy to .env and fill in for a self-hosted (Docker) deploy.
# On Vercel you can leave all of these unset — the platform auto-detects the URL.

# Production canonical origin. INLINED AT BUILD TIME (Docker build ARG), not runtime.
# Required for self-host so canonical/OpenGraph/sitemap/robots point at your domain.
NEXT_PUBLIC_SITE_URL=https://rentrights.example.org

# Upstream fetch timeout in ms (RUNTIME). Bounds slow LA County / Census calls;
# on timeout the lookup degrades to confirming questions. Default 12000.
UPSTREAM_TIMEOUT_MS=12000

# Search-console verification (RUNTIME, optional). The <meta> tags are omitted
# until these are set. Paste the values from Google Search Console / Bing.
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
