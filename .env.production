# Committed on purpose: the canonical production origin is not a secret, and
# `next build` loads this file, so the value is inlined consistently for
# prerendered routes (robots/sitemap/OG) and client bundles in every build
# environment (local, CI, Vercel). Analytics is cookieless Vercel Web Analytics
# (enabled in the Vercel project) — no token needed.
NEXT_PUBLIC_SITE_URL=https://rentrights.writingdeveloper.blog
